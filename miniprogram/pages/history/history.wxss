.history-container {
    padding: 20rpx;
    min-height: 100vh;
    background: #f5f5f5;
    padding-bottom: 40rpx;
}

.loading-state {
    text-align: center;
    padding: 100rpx;
    font-size: 28rpx;
    color: #999;
}

/* 分组卡片 */
.group-card {
    background: #fff;
    border-radius: 16rpx;
    margin-bottom: 16rpx;
    overflow: hidden;
    box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.group-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24rpx 28rpx;
    background: #fafafa;
}

.group-title {
    display: flex;
    align-items: center;
    gap: 10rpx;
    font-size: 28rpx;
    font-weight: bold;
    color: #333;
}

.group-icon {
    font-size: 20rpx;
    color: #999;
    transition: transform 0.2s;
    display: inline-block;
}
.group-icon.collapsed {
    transform: rotate(-90deg);
}

.group-count {
    font-size: 22rpx;
    color: #999;
    background: #f0f0f0;
    padding: 4rpx 14rpx;
    border-radius: 20rpx;
    font-weight: normal;
}

.group-actions {
    display: flex;
    gap: 16rpx;
}
.action-icon {
    font-size: 32rpx;
    padding: 4rpx;
}

.group-body {
    border-top: 1rpx solid #f0f0f0;
}

/* 笔记条目 */
.note-item {
    padding: 20rpx 28rpx;
    border-bottom: 1rpx solid #f5f5f5;
}
.note-item:last-child {
    border-bottom: none;
}

.note-item-row {
    display: flex;
    align-items: flex-start;
    gap: 12rpx;
}

.note-icons {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4rpx;
    padding-top: 2rpx;
}

.read-icon {
    font-size: 24rpx;
    line-height: 1;
    color: #ccc;
}
.read-icon.unread {
    color: #ff4d4f;
}
.read-icon.read {
    color: #ccc;
}

.star-icon {
    font-size: 36rpx;
    color: #ddd;
    line-height: 1.2;
}
.star-icon.starred {
    color: #ff9500;
}

.note-item-body {
    flex: 1;
    min-width: 0;
}

.note-title {
    font-size: 28rpx;
    color: #333;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
    margin-bottom: 6rpx;
    line-height: 1.4;
}

.note-memo {
    font-size: 24rpx;
    color: #999;
    margin-bottom: 6rpx;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.note-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.note-platform {
    font-size: 22rpx;
    color: #07c160;
    background: #f0f9f4;
    padding: 2rpx 10rpx;
    border-radius: 6rpx;
}

.note-date {
    font-size: 22rpx;
    color: #bbb;
}

/* 空状态 */
.empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 200rpx;
}
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 32rpx; color: #666; margin-bottom: 12rpx; }
.empty-hint { font-size: 26rpx; color: #999; }

/* 新建分类按钮 */
.add-category-btn {
    background: #fff;
    border: 2rpx dashed #ddd;
    border-radius: 16rpx;
    padding: 28rpx;
    text-align: center;
    margin-bottom: 20rpx;
    font-size: 28rpx;
    color: #07c160;
}

.empty-category-hint {
    padding: 24rpx 28rpx;
    text-align: center;
    font-size: 24rpx;
    color: #ccc;
}

.hint-text {
    text-align: center;
    font-size: 22rpx;
    color: #ccc;
    padding: 8rpx;
}
