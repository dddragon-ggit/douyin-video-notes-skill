.container {
    padding: 20rpx;
    min-height: 100vh;
    background: #f5f5f5;
    padding-bottom: 40rpx;
}

/* 输入区 */
.input-section {
    background: #fff;
    border-radius: 16rpx;
    padding: 24rpx;
    margin-bottom: 20rpx;
}

.title-row {
    margin-bottom: 16rpx;
}

.title-input {
    font-size: 30rpx;
    padding: 16rpx;
    background: #f8f8f8;
    border-radius: 8rpx;
}

.textarea-wrapper {
    position: relative;
}

.text-input {
    width: 100%;
    min-height: 300rpx;
    font-size: 28rpx;
    line-height: 1.6;
    padding: 16rpx;
    background: #f8f8f8;
    border-radius: 8rpx;
    box-sizing: border-box;
}

.char-count {
    text-align: right;
    font-size: 22rpx;
    color: #ccc;
    margin-top: 8rpx;
}

.input-actions {
    display: flex;
    gap: 16rpx;
    margin-top: 16rpx;
}

.btn-paste {
    flex: 1;
    font-size: 26rpx;
    padding: 12rpx 0;
    background: #f0f9f4;
    color: #07c160;
    border: 2rpx solid #07c160;
    border-radius: 12rpx;
    line-height: 1.5;
}
.btn-paste::after { border: none; }

.btn-clear {
    font-size: 26rpx;
    padding: 12rpx 24rpx;
    background: #fff;
    color: #999;
    border: 2rpx solid #ddd;
    border-radius: 12rpx;
    line-height: 1.5;
}
.btn-clear::after { border: none; }

/* 生成按钮 */
.btn-generate {
    width: 100%;
    font-size: 30rpx;
    padding: 24rpx 0;
    background: linear-gradient(135deg, #07c160, #06ad56);
    color: #fff;
    border-radius: 16rpx;
    font-weight: bold;
    margin-bottom: 24rpx;
}
.btn-generate::after { border: none; }
.btn-generate.disabled {
    background: #ccc;
}

/* 加载状态 */
.loading-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 60rpx 0;
}

.loading-spinner {
    width: 60rpx;
    height: 60rpx;
    border: 4rpx solid #eee;
    border-top: 4rpx solid #07c160;
    border-radius: 50%;
    animation: spin 1s linear infinite;
    margin-bottom: 20rpx;
}

@keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

.loading-text {
    font-size: 26rpx;
    color: #999;
}

/* 结果预览 */
.result-section {
    background: #fff;
    border-radius: 16rpx;
    padding: 28rpx;
}

.result-header {
    margin-bottom: 24rpx;
    padding-bottom: 16rpx;
    border-bottom: 1rpx solid #eee;
}

.result-title {
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
    display: block;
    margin-bottom: 8rpx;
}

.result-platform {
    font-size: 22rpx;
    color: #07c160;
    background: #f0f9f4;
    padding: 2rpx 10rpx;
    border-radius: 6rpx;
}

.result-block {
    margin-bottom: 28rpx;
}

.block-title {
    font-size: 28rpx;
    font-weight: bold;
    color: #333;
    margin-bottom: 16rpx;
    display: block;
}

.point-item {
    margin-bottom: 16rpx;
    padding-left: 16rpx;
    border-left: 4rpx solid #07c160;
}

.point-title {
    font-size: 28rpx;
    font-weight: bold;
    color: #333;
    display: block;
}

.point-desc {
    font-size: 26rpx;
    color: #666;
    display: block;
    margin-top: 4rpx;
}

.quote-item {
    margin-bottom: 12rpx;
    padding: 12rpx 16rpx;
    background: #f8f8f8;
    border-radius: 8rpx;
    border-left: 4rpx solid #ff9500;
}

.quote-text {
    font-size: 26rpx;
    color: #555;
    font-style: italic;
}

/* 操作按钮 */
.result-actions {
    display: flex;
    gap: 16rpx;
    margin-top: 24rpx;
    padding-top: 20rpx;
    border-top: 1rpx solid #eee;
}

.btn-view {
    flex: 2;
    font-size: 28rpx;
    padding: 16rpx 0;
    background: #07c160;
    color: #fff;
    border-radius: 12rpx;
    font-weight: bold;
}
.btn-view::after { border: none; }

.btn-copy {
    flex: 1;
    font-size: 26rpx;
    padding: 16rpx 0;
    background: #f0f9f4;
    color: #07c160;
    border: 2rpx solid #07c160;
    border-radius: 12rpx;
}
.btn-copy::after { border: none; }
