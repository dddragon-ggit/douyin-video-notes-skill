.settings-container {
    padding: 20rpx;
    min-height: 100vh;
    background: #f5f5f5;
}

.section {
    background: #fff;
    border-radius: 16rpx;
    margin-bottom: 24rpx;
    overflow: hidden;
}

.section-title {
    font-size: 26rpx;
    color: #999;
    padding: 24rpx 28rpx 12rpx;
}

.form-item {
    padding: 16rpx 28rpx 16rpx;
    border-bottom: 1rpx solid #f5f5f5;
}
.form-item:last-child {
    border-bottom: none;
    padding-bottom: 28rpx;
}

.form-label {
    font-size: 26rpx;
    color: #666;
    display: block;
    margin-bottom: 10rpx;
}

.form-input {
    background: #f8f8f8;
    padding: 16rpx 20rpx;
    border-radius: 10rpx;
    font-size: 28rpx;
    height: 44rpx;
    line-height: 44rpx;
}

.toggle-btn {
    font-size: 24rpx;
    color: #07c160;
    margin-left: 16rpx;
    white-space: nowrap;
}

.password-row {
    display: flex;
    align-items: center;
}
.flex-1 { flex: 1; }

.radio-group {
    display: flex;
    gap: 32rpx;
}
.radio-item {
    display: flex;
    align-items: center;
    font-size: 28rpx;
}
.radio-item radio {
    margin-right: 8rpx;
}

.button-group {
    display: flex;
    gap: 16rpx;
    margin-bottom: 24rpx;
}

.save-btn {
    flex: 1;
    background: #07c160;
    color: #fff;
    font-size: 28rpx;
    border-radius: 12rpx;
    height: 80rpx;
    line-height: 80rpx;
}
.save-btn::after { border: none; }

.clear-btn {
    flex: 1;
    background: #fff;
    color: #e74c3c;
    font-size: 28rpx;
    border: 2rpx solid #e74c3c;
    border-radius: 12rpx;
    height: 80rpx;
    line-height: 80rpx;
}
.clear-btn::after { border: none; }

.info-section {
    background: #fff;
    border-radius: 16rpx;
    padding: 24rpx 28rpx;
}
.info-title {
    font-size: 26rpx;
    color: #999;
    display: block;
    margin-bottom: 12rpx;
}
.info-text {
    font-size: 22rpx;
    color: #bbb;
    display: block;
    margin-bottom: 8rpx;
    line-height: 1.5;
}
